<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= appName %> — verification code</title>
</head>
<body style="margin: 0; padding: 0; font-family: 'Geist', 'Geist Sans', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif; background-color: #fafafa; color: #18181b;">
  <table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0" style="background-color: #fafafa; padding: 40px 16px;">
    <tr>
      <td align="center">
        <table role="presentation" width="520" border="0" cellpadding="0" cellspacing="0" style="max-width: 520px; background-color: #ffffff; border: 1px solid #e4e4e7; border-radius: 16px; box-shadow: 0 10px 40px -15px rgba(15, 23, 42, 0.14); overflow: hidden;">

            <tr>
              <td style="padding: 28px 32px; background: linear-gradient(135deg, #0ea5e9 0%, #2563eb 55%, #4338ca 100%);">
                <p style="margin: 0; font-size: 22px; font-weight: 700; letter-spacing: -0.01em; color: #ffffff;">
                  <%= appName %>
                </p>
                <p style="margin: 6px 0 0; font-size: 13px; font-weight: 500; color: rgba(255, 255, 255, 0.82); letter-spacing: 0.01em;">
                  One room for YouTube with everyone.
                </p>
              </td>
            </tr>

            <tr>
              <td style="padding: 36px 32px 28px;">
                <h1 style="margin: 0 0 10px; font-size: 22px; font-weight: 600; letter-spacing: -0.015em; color: #18181b;">
                  Your verification code
                </h1>
                <p style="margin: 0 0 28px; font-size: 15px; line-height: 1.6; color: #71717a;">
                  Enter this code to finish creating your account. It expires in
                  <strong style="color: #18181b; font-weight: 600;"><%= expiresInMinutes %> minute<%= expiresInMinutes === 1 ? "" : "s" %></strong>.
                </p>

                <table role="presentation" border="0" cellpadding="0" cellspacing="0" align="center" style="margin: 0 auto 28px;">
                  <tr>
                    <% for (let i = 0; i < otp.length; i++) { %>
                      <td width="44" height="44" align="center" valign="middle" style="width: 44px; height: 44px; padding: 0; background-color: #ffffff; border: 1px solid #e4e4e7; border-radius: 12px; font-family: 'Geist Mono', 'SF Mono', Menlo, Consolas, monospace; font-size: 24px; line-height: 44px; font-weight: 700; color: #18181b; text-align: center; vertical-align: middle; box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);">
                        <%= otp[i] %>
                      </td>
                      <% if (i < otp.length - 1) { %><td width="8" style="width: 8px; font-size: 0; line-height: 0;">&nbsp;</td><% } %>
                    <% } %>
                  </tr>
                </table>

                <p style="margin: 0; font-size: 13px; line-height: 1.6; color: #a1a1aa;">
                  If you didn't request this code, you can safely ignore this email.
                </p>
              </td>
            </tr>

            <tr>
              <td style="padding: 18px 32px; background-color: #fafafa; border-top: 1px solid #e4e4e7;">
                <p style="margin: 0; font-size: 12px; color: #a1a1aa; text-align: center; letter-spacing: 0.01em;">
                  &copy; <%= new Date().getFullYear() %> <%= appName %>. Never share this code with anyone.
                </p>
              </td>
            </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
